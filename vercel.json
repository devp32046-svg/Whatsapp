{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node"
    },
    {
      "src": "src/public/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "server.js"
    },
    {
      "src": "/(index.html)?",
      "dest": "src/public/index.html"
    },
    {
      "src": "/(.*)",
      "dest": "src/public/$1"
    }
  ]
}
