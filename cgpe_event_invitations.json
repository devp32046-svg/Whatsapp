    {
      "id": "2a3217f2-bc25-48ba-b1d7-d035204ae511",
      "name": "Build Invite",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        96
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const meta=$(\"Normalize\").first().json;\nconst idx=$(\"Fetch Targets\").all().map(function(i){return i.json;}).filter(function(j){return j&&Object.keys(j).length>0;});\nconst admins=$(\"Fetch Admins\").all().map(function(i){return i.json||{};});\nfunction norm(p){var d=String(p||\"\").replace(/[^0-9]/g,\"\");if(d.length>10)d=d.slice(-10);return d;}\nvar ap=admins.length?norm(admins[0].phoneLast10||admins[0].phone):\"9601775061\"; if(ap.length===10) ap=\"91\"+ap;\nvar t=String(meta.target||\"all\").toLowerCase();\nvar lim=parseInt(meta.limit,10); if(!isFinite(lim)||lim<1) lim=50;\nvar pool=idx.filter(function(r){ if(t===\"hni\") return r.flag_high_value===true; if(t===\"lowcover\") return r.flag_life_cover_under_1cr===true; return true; });\nvar recips=[];\nfor(var i=0;i<pool.length && recips.length<lim;i++){ var ph=norm(pool[i].phone||pool[i].phoneLast10); if(ph.length===10) recips.push({name:pool[i].name, phone:ph}); }\nvar invite=\"🎉 Aapne CGPE na '\"+meta.title+\"' ma aamantran! 📅 \"+meta.date+\"  📍 \"+meta.location+\". Aapni hajari amaara maate kimti chhe. Aavva mate 'YES' reply karo. 🙏 — C. G. Patel Enterprise\";\nvar sample=recips.slice(0,10).map(function(r,i){ return (i+1)+\". \"+r.name+\" (\"+r.phone+\")\"; });\nvar text=\"🎉 Event invite ready: \"+meta.title+\" (\"+meta.date+\")\\nTarget: \"+t+\" — \"+recips.length+\" recipients\\n\\nInvite text:\\n\"+invite+\"\\n\\nSample:\\n\"+(sample.join(\"\\n\")||\"-\")+\"\\n\\nBulk send karva Campaign Broadcaster vaaparo.\";\nreturn [{ json: { phone:ap, text:text, purpose:\"event_invite\", ok:true, eventId:meta.eventId, title:meta.title, targetType:t, count:recips.length, requested:lim, inviteText:invite, createdAt:new Date().toISOString() } }];"
      }
    },
