        "jsCode": "const j=$input.first()?($input.first().json||{}):{};\nvar t=String(j.target||\"all\").toLowerCase();\nvar q=\"{}\"; if(t===\"hni\") q='{\"flag_high_value\":true}'; else if(t===\"lowcover\") q='{\"flag_life_cover_under_1cr\":true}';\nvar lim=parseInt(j.limit||50,10); if(!isFinite(lim)||lim<1) lim=50;\nreturn [{ json: { eventId:String(j.eventId||(\"EVT-\"+Date.now())), title:String(j.title||\"CGPE Event\"), date:String(j.date||\"\"), location:String(j.location||\"\"), target:t, mongoQuery:q, limit:lim } }];"
