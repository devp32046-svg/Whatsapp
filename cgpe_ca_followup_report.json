    {
      "id": "22d3a8cb-a2dc-497b-9daf-d3ff290b2b4f",
      "name": "Decide",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        440,
        0
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const inp = $input.first() ? ($input.first().json||{}) : {};\nvar forced = String(inp.testMode||'').trim().toLowerCase();\nvar d = new Date(new Date().getTime()+5.5*3600*1000);\nvar dow = d.getUTCDay();\nvar diff = (dow===0?-6:1-dow); var monday=new Date(d.getTime()+diff*86400000);\nvar weekKey = monday.toISOString().slice(0,10);\nvar mode;\nif (forced) { mode = forced; }\nelse if (dow===3||dow===5) { mode='followup'; }\nelse if (dow===0) { mode='report'; }\nelse { mode='none'; }\nreturn [{ json: { mode:mode, weekKey:weekKey } }];"
      }
    },
    {
      "id": "73176f5a-e031-43fb-8bcf-1592b4825288",
      "name": "Should Run?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        660,
        0
      ],
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "leftValue": "={{ $json.mode }}",
              "operator": {
                "type": "string",
                "operation": "notEquals"
              },
              "rightValue": "none"
            }
          ],
          "combinator": "and"
        }
      }
    },
    {
      "id": "3e0e59b7-2bcd-4ffb-8fc5-0b76a28b68d3",
      "name": "Fetch FU Week",
      "type": "n8n-nodes-base.mongoDb",
      "typeVersion": 1.3,
      "position": [
        1100,
        -80
      ],
      "parameters": {
        "resource": "document",
        "operation": "find",
        "collection": "ca_followups",
        "query": "={{ JSON.stringify({ weekKey: $('Decide').first().json.weekKey }) }}",
        "options": {
          "limit": 500
        }
      },
      "credentials": {
        "mongoDb": {
          "id": "WZ2iSk9j0aJMoLDk",
