  "nodes": [
    {
      "id": "0089b65e-5d9e-4096-b5b8-d369cece7176",
      "name": "Daily Check",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [
        0,
        -120
      ],
      "parameters": {
        "rule": {
          "interval": [
