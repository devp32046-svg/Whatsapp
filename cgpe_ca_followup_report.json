    {
      "id": "9aecf845-5602-43ad-9334-070dd65c1e0a",
      "name": "Compose",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1320,
        -80
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const rows = $input.all().map(function(i){ return i.json; }).filter(function(j){ return j && j.firmName; });\nconst meta = $('Decide').first().json || {};\nvar ap = '919601775061';\nvar pending = rows.filter(function(r){ return String(r.status||'pending')==='pending'; });\nvar replied = rows.filter(function(r){ return String(r.status||'')==='replied'; });\nvar text;\nif (meta.mode==='report') {\n  var lines = rows.map(function(c,i){ return (i+1)+'. '+c.firmName+' - '+(c.status||'pending'); });\n  text = 'CGPE CA weekly report (Sunday). This week: ' + rows.length + ' CAs assigned, ' + replied.length + ' replied, ' + pending.length + ' pending.\\n\\n' + (lines.length?lines.join('\\n'):'No CAs assigned this week.');\n} else {\n  var lines2 = pending.map(function(c,i){ return (i+1)+'. '+c.firmName+(c.phone?(' - '+c.phone):''); });\n  text = 'CGPE CA follow-up reminder. These CAs have not replied yet - please follow up:\\n\\n' + (lines2.length?lines2.join('\\n'):'All CAs have replied. Nothing pending.');\n}\nreturn [{ json: { phone: ap, text: text, purpose: 'ca_'+(meta.mode||'digest') } }];"
      }
    },
