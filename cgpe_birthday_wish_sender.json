    {
      "id": "a656c8da-3fea-414a-96d6-dc817573cf38",
      "name": "Filter Today",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        192
      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const today = new Date().toISOString().slice(0,10);\nfunction tc(s){ return String(s||\"\").toLowerCase().replace(/\\b\\w/g, function(m){ return m.toUpperCase(); }); }\nfunction norm(p){ var d = String(p||\"\").replace(/[^0-9]/g,\"\"); if(d.length>10) d=d.slice(-10); return d; }\nconst rows = $input.all().map(function(i){ return i.json; }).filter(function(j){ return j && Object.keys(j).length>0; });\nconst out = [];\nrows.forEach(function(r){\n  if (r.sentBirthdayOn === today) return;\n  var ten = norm(r.phone || r.phoneLast10);\n  if (ten.length !== 10) return;\n  var nm = tc(r.name);\n  var wish = \"🎂 Janmadin ni hardik shubhkaamnaao, \" + nm + \"! CGPE parivaar taraf thi tamne aarogya, samruddhi ane khushiyo thi bharpoor varsh ni shubhechhao. 🙏 — C. G. Patel Enterprise\";\n  out.push({ json: { personKey: r.personKey, name: nm, phone: \"91\"+ten, text: wish, purpose: \"birthday_wish\", sentBirthdayOn: today } });\n});\nreturn out;"
      }
    },
