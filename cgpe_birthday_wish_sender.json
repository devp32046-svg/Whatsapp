      ],
      "parameters": {
        "mode": "runOnceForAllItems",
        "language": "javaScript",
        "jsCode": "const list = $(\"Filter Today\").all().map(function(i){ return i.json; });\nconst admins = $(\"Fetch Admins\").all().map(function(i){ return i.json||{}; });\nfunction norm(p){ var d=String(p||\"\").replace(/[^0-9]/g,\"\"); if(d.length>10) d=d.slice(-10); return d; }\nvar ap = admins.length ? norm(admins[0].phoneLast10||admins[0].phone) : \"9601775061\";\nif (ap.length===10) ap = \"91\"+ap;\nif (!list.length) { return [{ json: { phone: ap, text: \"🎂 Aaje koi client no janmadin nathi.\", purpose: \"birthday_admin_summary\" } }]; }\nvar lines = list.map(function(p,i){ return (i+1)+\". \"+p.name+\" (\"+p.phone+\")\"; });\nvar text = \"🎂 Aaje na birthdays: \"+list.length+\"\\n\\n\"+lines.join(\"\\n\")+\"\\n\\nPersonalised birthday wishes bot dwara mokli didha.\";\nreturn [{ json: { phone: ap, text: text, purpose: \"birthday_admin_summary\" } }];"
      },
